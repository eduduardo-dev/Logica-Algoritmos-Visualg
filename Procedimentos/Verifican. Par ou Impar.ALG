algoritmo "semnome"
var
   Num: Inteiro
Procedimento ParOuImpar(Valor: inteiro)
inicio
   Se (Valor % 2 = 0) entao
      Escreval("O Numero ", Valor, " ť Par")
   Senao
      Escreval("O numnero ", Valor, " ť Impar")
   FimSe
FimProcedimento
inicio
     Escreva("Digite um numero: ")
     Leia(Num)
     ParOuImpar (Num)
fimalgoritmo